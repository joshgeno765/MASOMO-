# Database — PostgreSQL. In production this is Railway's managed Postgres
# plugin's connection string. For local dev, point this at any Postgres
# instance (Railway's, a local install, or a free hosted one) — SQLite is
# no longer used because Railway's container filesystem is ephemeral and
# wipes on every redeploy.
DATABASE_URL="postgresql://masomo:yourpassword@localhost:5432/masomo_now"

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# JWT Secret (Week 3 — generate a strong random string)
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_REFRESH_SECRET=replace_this_with_another_long_random_secret

# Email (Week 2)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
